// Zed keymap - https://zed.dev/docs/key-bindings
[
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-tab": "tab_switcher::ToggleAll",
      "ctrl-alt-l": "zed::OpenLog",

      "ctrl-up": "workspace::ActivatePaneUp",
      "ctrl-down": "workspace::ActivatePaneDown",
      "ctrl-left": "workspace::ActivatePaneLeft",
      "ctrl-right": "workspace::ActivatePaneRight",

      "cmd-b": "multi_workspace::ToggleWorkspaceSidebar",
      "cmd-l": "workspace::ToggleLeftDock",

      "cmd-shift-a": "agent::ToggleFocus",
      "cmd-shift-d": "debug_panel::Toggle",
      "cmd-shift-g": "git_panel::ToggleFocus",
      "cmd-shift-s": "multi_workspace::FocusWorkspaceSidebar",
      "cmd-shift-t": "terminal_panel::ToggleFocus",

      "cmd-ctrl-alt-r": "editor::RestartLanguageServer",
      "cmd-ctrl-alt-v": "workspace::ToggleVimMode",
      "cmd-ctrl-alt-s": "zed::OpenSettingsFile",
      "cmd-ctrl-alt-k": "zed::OpenKeymapFile",
    },
  },

  // Editor --------------------------------------------------------------------

  {
    "context": "Editor",
    "bindings": {
      "ctrl-space": "editor::ShowCompletions",
      "shift-alt-i": "editor::SplitSelectionIntoLines",
    },
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "space p a": "pane::JoinAll",
      "space p n": "pane::JoinIntoNext",
      "space p c": "workspace::ToggleCenteredLayout",
      "space p u": "pane::SplitAndMoveUp",
      "space p d": "pane::SplitAndMoveDown",
      "space p l": "pane::SplitAndMoveLeft",
      "space p r": "pane::SplitAndMoveRight",
    },
  },

  // Agent Panel ---------------------------------------------------------------

  {
    "context": "AgentPanel",
    "bindings": {
      "ctrl-x g g": "agent::ScrollOutputToTop",
      "ctrl-x shift-g": "agent::ScrollOutputToBottom",
      "ctrl-x m": "agent::ToggleModelSelector",
      "ctrl-x d": "agent::OpenAgentDiff",
      "ctrl-x n": "agent::NewThread",
    },
  },
  {
    "context": "AgentPanel > Editor && vim_mode == normal && !menu",
    "bindings": {
      "ctrl-e": "agent::ScrollOutputLineDown",
      "ctrl-y": "agent::ScrollOutputLineUp",
      "ctrl-f": "agent::ScrollOutputPageDown",
      "ctrl-b": "agent::ScrollOutputPageUp",
      "ctrl-p": "agent::ScrollOutputToPreviousMessage",
      "ctrl-n": "agent::ScrollOutputToNextMessage",
    },
  },

  // Project Panel -------------------------------------------------------------

  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "c": "project_panel::CollapseAllEntries",
    },
  },

  // Git Panel -----------------------------------------------------------------

  {
    "context": "GitPanel && ChangesList",
    "bindings": {
      "h": "git::FileHistory",
      "t": "git_panel::ToggleTreeView",
      "f": ["workspace::SendKeystrokes", "enter enter"], // Focus file
      "d": ["workspace::SendKeystrokes", "ctrl-enter cmd-shift-g"], // Open diff
    },
  },
  {
    "context": "GitCommit",
    "bindings": {
      "ctrl-x g": "git::GenerateCommitMessage",
    },
  },
  {
    "context": "(AgentDiff || FileDiff || GitDiff) > Editor && (vim_mode == normal || vim_mode == visual)",
    "bindings": {
      "z d": "editor::ToggleSplitDiff",
    },
  },

  // Outline Panel -------------------------------------------------------------

  {
    "context": "OutlinePanel",
    "bindings": {
      "c": "outline_panel::CollapseAllEntries",
      "e": "outline_panel::ExpandAllEntries",
    },
  },

  // Vim -----------------------------------------------------------------------

  {
    "context": "VimControl && !menu",
    "bindings": {
      "z shift-f": "editor::ToggleFoldAll",
    },
  },
  {
    "context": "Editor && VimControl && !VimCount && !menu",
    "bindings": {
      "k": ["vim::Up", { "display_lines": true }],
      "j": ["vim::Down", { "display_lines": true }],
      "up": ["vim::Up", { "display_lines": true }],
      "down": ["vim::Down", { "display_lines": true }],
    },
  },
  {
    "context": "vim_mode == normal",
    "bindings": {
      "s": "vim::PushSneak",
      "shift-s": "vim::PushSneakBackward",
      "g s": "vim::HelixJumpToWord",
    },
  },
  {
    "context": "vim_mode == visual",
    "bindings": {
      "s": "vim::PushAddSurrounds",
      "p": ["workspace::SendKeystrokes", "\" _ d shift-p"], // Paste without clobbering unnamed register
    },
  },
  {
    "context": "vim_operator == a || vim_operator == i || vim_operator == cs || vim_operator == ds",
    "bindings": {
      // Traditional Vim behavior
      "q": "vim::AnyQuotes",
      "b": "vim::AnyBrackets",
      // mini.ai plugin behavior
      "Q": "vim::MiniQuotes",
      "B": "vim::MiniBrackets",
    },
  },

  // Unbind --------------------------------------------------------------------

  {
    "context": "Workspace",
    "unbind": {
      "cmd-b": "workspace::ToggleLeftDock",
      "cmd-shift-s": "workspace::SaveAs",
    },
  },
  {
    "context": "Pane",
    "unbind": {
      "cmd-shift-g": "search::SelectPreviousMatch", // git_panel::ToggleFocus
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "cmd-l": "editor::SelectLine", // multi_workspace::ToggleWorkspaceSidebar
      "ctrl-up": "editor::MoveToStartOfParagraph", // workspace::ActivatePaneUp
      "ctrl-down": "editor::MoveToEndOfParagraph", // workspace::ActivatePaneDown
    },
  },
  {
    "context": "TabSwitcher",
    "unbind": {
      "ctrl-up": "menu::SelectPrevious", // workspace::ActivatePaneUp
      "ctrl-down": "menu::SelectNext", // workspace::ActivatePaneDown
    },
  },
  {
    "context": "RecentProjects || RecentProjects > Picker > Editor",
    "unbind": {
      "cmd-shift-a": "workspace::AddFolderToProject", // agent::ToggleFocus
    },
  },
]
