// Zed keymap - https://zed.dev/docs/key-bindings
[
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-tab": "tab_switcher::ToggleAll",

      "ctrl-up": "workspace::ActivatePaneUp",
      "ctrl-down": "workspace::ActivatePaneDown",
      "ctrl-left": "workspace::ActivatePaneLeft",
      "ctrl-right": "workspace::ActivatePaneRight",

      "cmd-l": "multi_workspace::ToggleWorkspaceSidebar",
      "ctrl-x l": "multi_workspace::ToggleWorkspaceSidebar",

      "cmd-shift-a": "agent::ToggleFocus",
      "cmd-shift-d": "debug_panel::Toggle",
      "cmd-shift-g": "git_panel::ToggleFocus",
      "cmd-shift-s": "multi_workspace::FocusWorkspaceSidebar",
      "cmd-shift-t": "terminal_panel::ToggleFocus",

      "cmd-ctrl-alt-r": "editor::RestartLanguageServer",
      "cmd-ctrl-alt-v": "workspace::ToggleVimMode",
      "cmd-ctrl-alt-s": "zed::OpenSettingsFile",
      "cmd-ctrl-alt-k": "zed::OpenKeymapFile",
    },
  },

  // ========================================
  // EDITOR
  // ========================================

  {
    "context": "Editor",
    "bindings": {
      "ctrl-space": "editor::ShowCompletions",
      "shift-alt-i": "editor::SplitSelectionIntoLines",
    },
  },

  // ========================================
  // AGENT PANEL
  // ========================================

  {
    "context": "AgentPanel",
    "bindings": {
      "ctrl-x a": "agent::CycleModeSelector",
      "ctrl-x m": "agent::ToggleModelSelector",
      "ctrl-x n": "agent::NewThread",
    },
  },

  // ========================================
  // PROJECT PANEL
  // ========================================

  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "c": "project_panel::CollapseAllEntries",
    },
  },

  // ========================================
  // GIT PANEL
  // ========================================

  {
    "context": "GitPanel && ChangesList",
    "bindings": {
      "h": "git::FileHistory",
      "t": "git_panel::ToggleTreeView",
      "f": ["workspace::SendKeystrokes", "enter enter"], // Focus file
      "d": ["workspace::SendKeystrokes", "ctrl-enter cmd-shift-g"], // Open diff
    },
  },
  {
    "context": "GitDiff > Editor && (vim_mode == normal || vim_mode == visual)",
    "bindings": {
      "z d": "editor::ToggleSplitDiff",
    },
  },

  // ========================================
  // VIM
  // ========================================

  {
    "context": "vim_mode == normal",
    "bindings": {
      "s": "vim::PushSneak",
      "shift-s": "vim::PushSneakBackward",
    },
  },
  {
    "context": "vim_mode == visual",
    "bindings": {
      "shift-s": "vim::PushAddSurrounds",
    },
  },
  {
    "context": "vim_operator == a || vim_operator == i || vim_operator == cs || vim_operator == ds",
    "bindings": {
      // Traditional Vim behavior
      "q": "vim::AnyQuotes",
      "b": "vim::AnyBrackets",
      // mini.ai plugin behavior
      "Q": "vim::MiniQuotes",
      "B": "vim::MiniBrackets",
    },
  },

  // ========================================
  // UNBIND
  // ========================================

  {
    "context": "Workspace",
    "unbind": {
      "cmd-shift-s": "workspace::SaveAs",
    },
  },
  {
    "context": "Pane",
    "unbind": {
      "cmd-shift-g": "search::SelectPreviousMatch", // git_panel::ToggleFocus
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "cmd-l": "editor::SelectLine", // multi_workspace::ToggleWorkspaceSidebar
      "ctrl-up": "editor::MoveToStartOfParagraph", // workspace::ActivatePaneUp
      "ctrl-down": "editor::MoveToEndOfParagraph", // workspace::ActivatePaneDown
    },
  },
  {
    "context": "TabSwitcher",
    "unbind": {
      "ctrl-up": "menu::SelectPrevious", // workspace::ActivatePaneUp
      "ctrl-down": "menu::SelectNext", // workspace::ActivatePaneDown
    },
  },
  {
    "context": "AgentPanel",
    "unbind": {
      "cmd-shift-t": "agent::CycleStartThreadIn", // terminal_panel::ToggleFocus
    },
  },
  {
    "context": "RecentProjects || RecentProjects > Picker > Editor",
    "unbind": {
      "cmd-shift-a": "workspace::AddFolderToProject", // agent::ToggleFocus
    },
  },
]
