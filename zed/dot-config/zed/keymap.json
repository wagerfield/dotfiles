// Zed keymap - https://zed.dev/docs/key-bindings
[
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-tab": "tab_switcher::ToggleAll",

      "ctrl-up": "workspace::ActivatePaneUp",
      "ctrl-down": "workspace::ActivatePaneDown",
      "ctrl-left": "workspace::ActivatePaneLeft",
      "ctrl-right": "workspace::ActivatePaneRight",

      "cmd-shift-g": "git_panel::ToggleFocus",
      "cmd-shift-t": "terminal_panel::ToggleFocus",

      "cmd-ctrl-alt-r": "editor::RestartLanguageServer",
      "cmd-ctrl-alt-v": "workspace::ToggleVimMode",
      "cmd-ctrl-alt-s": "zed::OpenSettingsFile",
      "cmd-ctrl-alt-k": "zed::OpenKeymapFile",
    },
  },

  // ----------------------------------------
  // PANE
  // ----------------------------------------
  {
    "context": "Pane",
    "bindings": {
      "cmd-shift-g": "git_panel::ToggleFocus",
    },
  },

  // ----------------------------------------
  // EDITOR
  // ----------------------------------------
  {
    "context": "Editor",
    "bindings": {
      "ctrl-up": "workspace::ActivatePaneUp",
      "ctrl-down": "workspace::ActivatePaneDown",
      "shift-alt-i": "editor::SplitSelectionIntoLines",
    },
  },

  // ----------------------------------------
  // PROJECT PANEL
  // ----------------------------------------
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "c": "project_panel::CollapseAllEntries",
    },
  },

  // ----------------------------------------
  // GIT PANEL
  // ----------------------------------------
  {
    "context": "GitPanel && ChangesList",
    "bindings": {
      "h": "git::FileHistory",
      "t": "git_panel::ToggleTreeView",
      "d": ["workspace::SendKeystrokes", "ctrl-enter cmd-shift-g"], // Open file diff
      "o": ["workspace::SendKeystrokes", "enter alt-enter"], // Open and focus file
    },
  },

  // ----------------------------------------
  // VIM
  // ----------------------------------------
  {
    "context": "vim_mode == normal || vim_mode == visual",
    "bindings": {
      "s": "vim::PushSneak",
      "shift-s": "vim::PushSneakBackward",
    },
  },
  {
    "context": "vim_operator == a || vim_operator == i || vim_operator == cs || vim_operator == ds",
    "bindings": {
      // Traditional Vim behavior
      "q": "vim::AnyQuotes",
      "b": "vim::AnyBrackets",
      // mini.ai plugin behavior
      "Q": "vim::MiniQuotes",
      "B": "vim::MiniBrackets",
    },
  },
]
