// Zed settings - https://zed.dev/docs/configuring-zed
{
  "ui_font_family": "JetBrains Mono",
  "ui_font_size": 15,

  "buffer_font_family": "JetBrains Mono",
  "buffer_line_height": "comfortable",
  "buffer_font_size": 14,

  "agent_ui_font_size": 15, // match ui_font_size
  "agent_buffer_font_size": 14, // match buffer_font_size

  "horizontal_scroll_margin": 8,
  "vertical_scroll_margin": 4,

  "auto_signature_help": true,
  "inline_code_actions": false,

  "selection_highlight": true,
  "rounded_selection": false,

  "resize_all_panels_in_dock": ["left", "right", "bottom"],
  "pane_split_direction_horizontal": "down",
  "pane_split_direction_vertical": "right",

  "multi_cursor_modifier": "cmd_or_ctrl",
  "relative_line_numbers": "enabled",
  "format_on_save": "on",

  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },

  // ========================================
  // PROFILES
  // ========================================

  "profiles": {
    "Presentation": {
      "ui_font_size": 17,
      "buffer_font_size": 16,
      "agent_ui_font_size": 17,
      "agent_buffer_font_size": 16,
      "redact_private_values": true,
    },
  },

  // ========================================
  // VIM
  // ========================================

  "vim_mode": true,
  "vim": {
    "toggle_relative_line_numbers": true,
    "highlight_on_yank_duration": 400,
    "use_system_clipboard": "always",
    "use_smartcase_find": true,
  },

  // ========================================
  // THEME
  // ========================================

  "icon_theme": {
    "mode": "dark",
    "light": "Base Charmed Icons",
    "dark": "Soft Charmed Icons",
  },
  "theme": {
    "mode": "dark",
    "light": "Zedokai Light",
    "dark": "Everforest Dark Medium (material)",
  },
  "theme_overrides": {
    "Everforest Dark Medium (material)": {
      "tab.active_background": "#2d353b",
      "panel.focused_border": "#7FBBB3",
      "debugger.accent": "#e67e80",
      // element
      "element.selected": "#343f44",
      "element.hover": "#343f44",
      // ghost_element
      "ghost_element.selected": "#343f44",
      "ghost_element.hover": "#343f44",
      // border
      "border.variant": "#3d484d",
      "border": "#3d484d",
      // misc
      "predictive": "#859289",
      "hint": "#859289",
    },
  },

  // ========================================
  // UI
  // ========================================

  "title_bar": {
    "show_branch_icon": false,
    "show_onboarding_banner": false,
    "show_user_menu": false,
  },
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "tabs": {
    "file_icons": false,
  },
  "toolbar": {
    "quick_actions": false,
    "breadcrumbs": true,
  },
  "gutter": {
    "min_line_number_digits": 4,
  },
  "scrollbar": {
    "show": "never",
  },
  "sticky_scroll": {
    "enabled": false,
  },
  "diagnostics": {
    "inline": {
      "enabled": false,
    },
  },

  // ========================================
  // PANELS
  // ========================================

  "project_panel": {
    "default_width": 320,
    "entry_spacing": "comfortable",
    "auto_reveal_entries": true,
    "auto_fold_dirs": false,
    "git_status": false,
    "hide_root": true,
  },
  "git_panel": {
    "default_width": 320,
    "folder_icons": false,
    "file_icons": false,
    "tree_view": true,
  },
  "outline_panel": {
    "default_width": 320,
  },
  "collaboration_panel": {
    "default_width": 320,
  },
  "search": {
    "button": false,
    "center_on_match": true,
  },
  "notification_panel": {
    "default_width": 320,
    "button": false,
    "dock": "left",
  },
  "terminal": {
    "minimum_contrast": 0,
    "default_height": 320,
    "default_width": 720,
    "dock": "right",
  },

  // ========================================
  // AI
  // ========================================

  "agent": {
    "default_width": 720,
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-haiku-4.5",
      "enable_thinking": false,
    },
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
    "opencode": {
      "type": "registry",
      "default_model": "opencode-go/kimi-k2.5",
      "favorite_models": [
        "anthropic/claude-sonnet-4-6",
        "anthropic/claude-opus-4-6",
        "opencode/big-pickle",
        "opencode-go/glm-5",
        "opencode-go/kimi-k2.5",
        "opencode-go/minimax-m2.7",
      ],
    },
  },
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {
        "context7_api_key": "ctx7sk-41c0cdc5-742d-44e2-a54d-46175401d4f4",
      },
    },
  },
  "edit_predictions": {
    "provider": "copilot",
    "mode": "eager",
  },

  // ========================================
  // EXTENSIONS
  // ========================================

  "auto_install_extensions": {
    // Themes
    "catppuccin": true,
    "everforest": true,
    "rose-pine-theme": true,
    "tokyo-night": true,
    "zedokai": true,

    // Icon Themes
    "catppuccin-icons": true,
    "charmed-icons": true,

    // Language Servers
    "astro": true,
    "biome": true,
    "cspell": true,
    "csv": true,
    "dockerfile": true,
    "git-firefly": true,
    "glsl": true,
    "html": true,
    "lua": true,
    "markdown-oxide": true,
    "markdownlint": true,
    "mermaid": true,
    "rainbow-csv": true,
    "sql": true,
    "svelte": true,
    "terraform": true,
    "toml": true,
    "vue": true,
    "wgsl-wesl": true,

    // MCP Servers
    "browser-tools-context-server": true,
    "chrome-devtools-mcp": true,
    "mcp-server-brave-search": true,
    "mcp-server-context7": true,
    "mcp-server-github": true,
    "mcp-server-nextjs": true,
    "mcp-server-notion": true,
    "mcp-server-playwright": true,
    "mcp-server-resend": true,
    "mcp-server-supabase": true,
    "postgres-context-server": true,
    "sentry-mcp": true,
    "shadcn-mcp": true,
    "svelte-mcp": true,
  },
}
