// Zed settings - https://zed.dev/docs/configuring-zed
{
  "ui_font_family": "JetBrains Mono",
  "ui_font_size": 15,

  "buffer_font_family": "JetBrains Mono",
  "buffer_line_height": "comfortable",
  "buffer_font_size": 14,

  "agent_ui_font_size": 15, // match ui_font_size
  "agent_buffer_font_size": 14, // match buffer_font_size

  "horizontal_scroll_margin": 8,
  "vertical_scroll_margin": 4,

  "auto_signature_help": true,
  "inline_code_actions": false,

  "rounded_selection": false,
  "selection_highlight": true,

  "resize_all_panels_in_dock": ["left", "right", "bottom"],
  "pane_split_direction_horizontal": "down",
  "pane_split_direction_vertical": "right",

  "relative_line_numbers": "enabled",
  "format_on_save": "on",

  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },

  // ========================================
  // PROFILES
  // ========================================

  "profiles": {
    "Presentation": {
      "settings": {
        "ui_font_size": 17,
        "buffer_font_size": 16,
        "agent_ui_font_size": 17,
        "agent_buffer_font_size": 16,
        "redact_private_values": true,
      },
    },
  },

  // ========================================
  // VIM
  // ========================================

  "vim_mode": true,
  "vim": {
    "toggle_relative_line_numbers": true,
    "highlight_on_yank_duration": 400,
    "use_system_clipboard": "always",
    "use_smartcase_find": true,
  },

  // ========================================
  // THEME
  // ========================================

  "icon_theme": {
    "mode": "system",
    "light": "Base Charmed Icons",
    "dark": "Soft Charmed Icons",
  },
  "theme": {
    "mode": "system",
    "light": "Fleet Light",
    "dark": "Zedokai Darker (Filter Octagon)",
  },
  // https://zed.dev/theme-builder
  "theme_overrides": {
    "Catppuccin Latte": {
      "border.variant": "#ccd0da",
    },
    "Everforest Dark Medium (material)": {
      "tab.active_background": "#2d353b",
      "panel.focused_border": "#7fbbb3",
      "debugger.accent": "#e67e80",
      // element
      "element.selected": "#343f44",
      "element.hover": "#343f44",
      // ghost_element
      "ghost_element.selected": "#343f44",
      "ghost_element.hover": "#343f44",
      // border
      "border.variant": "#3d484d",
      "border": "#3d484d",
      // misc
      "predictive": "#859289",
      "hint": "#859289",
    },
  },

  // ========================================
  // UI
  // ========================================

  "title_bar": {
    "show_branch_icon": false,
    "show_onboarding_banner": false,
    "show_user_menu": false,
  },
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "tabs": {
    "file_icons": false,
  },
  "toolbar": {
    "quick_actions": false,
    "breadcrumbs": true,
  },
  "gutter": {
    "min_line_number_digits": 4,
    "runnables": false,
  },
  "scrollbar": {
    "show": "never",
  },
  "sticky_scroll": {
    "enabled": false,
  },
  "diagnostics": {
    "inline": {
      "enabled": false,
    },
  },

  // ========================================
  // PANELS
  // ========================================

  "project_panel": {
    "default_width": 360,
    "entry_spacing": "comfortable",
    "auto_reveal_entries": true,
    "auto_fold_dirs": false,
    "git_status": false,
    "hide_root": true,
  },
  "git_panel": {
    "default_width": 360,
    "folder_icons": false,
    "file_icons": false,
    "tree_view": true,
  },
  "outline_panel": {
    "default_width": 360,
  },
  "collaboration_panel": {
    "default_width": 360,
  },
  "search": {
    "button": false,
    "center_on_match": true,
  },
  "terminal": {
    "minimum_contrast": 0,
    "default_height": 360,
    "default_width": 720,
    "dock": "left",
  },

  // ========================================
  // AI
  // ========================================

  "agent": {
    "default_width": 720,
    "max_content_width": 720,
    "expand_edit_card": false,
    "expand_terminal_card": false,
    "play_sound_when_agent_done": "when_hidden",
    "notify_when_agent_waiting": "all_screens",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-4o",
      "enable_thinking": false,
    },
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-4o",
      "enable_thinking": false,
    },
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
    "pi-acp": {
      "type": "registry",
      "favorite_models": [
        "opencode-go/glm-5",
        "opencode-go/glm-5.1",
        "opencode-go/kimi-k2.5",
        "opencode-go/minimax-m2.7",
      ],
    },
    "opencode": {
      "type": "registry",
      "default_config_options": {
        "model": "openai/gpt-5.4",
        "mode": "plan",
      },
      "favorite_config_option_values": {
        "model": [
          "openai/gpt-5.4",
          "opencode-go/glm-5",
          "opencode-go/glm-5.1",
          "opencode-go/kimi-k2.5",
          "opencode-go/minimax-m2.7",
          "openai/gpt-5.4/medium",
          "openai/gpt-5.4/high",
          "openai/gpt-5.3-codex/medium",
          "openai/gpt-5.3-codex/high",
        ],
      },
    },
  },
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {
        "context7_api_key": "ctx7sk-41c0cdc5-742d-44e2-a54d-46175401d4f4",
      },
    },
  },
  "edit_predictions": {
    "provider": "copilot",
    "mode": "eager",
  },

  // ========================================
  // EXTENSIONS
  // ========================================

  "auto_install_extensions": {
    // Themes
    "catppuccin": true,
    "everforest": true,
    "fleet-themes": true,
    "github-theme": true,
    "rose-pine-theme": true,
    "tokyo-night": true,
    "zedokai": true,

    // Icon Themes
    "catppuccin-icons": true,
    "charmed-icons": true,

    // Language Servers
    "astro": true,
    "biome": true,
    "cspell": true,
    "csv": true,
    "dockerfile": true,
    "git-firefly": true,
    "glsl": true,
    "html": true,
    "lua": true,
    "markdown-oxide": true,
    "markdownlint": true,
    "mdx": true,
    "mermaid": true,
    "rainbow-csv": true,
    "sql": true,
    "svelte": true,
    "terraform": true,
    "toml": true,
    "vue": true,
    "wgsl-wesl": true,
    "xml": true,

    // MCP Servers
    "browser-tools-context-server": true,
    "chrome-devtools-mcp": true,
    "mcp-server-brave-search": true,
    "mcp-server-context7": true,
    "mcp-server-github": true,
    "mcp-server-nextjs": true,
    "mcp-server-notion": true,
    "mcp-server-playwright": true,
    "mcp-server-resend": true,
    "mcp-server-supabase": true,
    "postgres-context-server": true,
    "sentry-mcp": true,
    "shadcn-mcp": true,
    "svelte-mcp": true,
  },

  // ========================================
  // LSP
  // ========================================

  "lsp": {
    "biome": {
      "settings": {
        "require_config_file": true,
      },
    },
  },
}
